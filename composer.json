{
  "name": "imigio/imigio-bundle",
  "description": "Symfony bundle for Imig.io integration",
  "type": "symfony-bundle",
  "keywords": [
    "images",
    "storage",
    "transform"
  ],
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.10",
    "symfony/config": "^4.0|^5.0|^6.0|^7.0",
    "symfony/console": "^4.0|^5.0|^6.0|^7.0",
    "symfony/dependency-injection": "^4.0|^5.0|^6.0|^7.0",
    "symfony/filesystem": "^4.0|^5.0|^6.0|^7.0",
    "symfony/framework-bundle": "^4.0|^5.0|^6.0|^7.0",
    "symfony/http-kernel": "^4.0|^5.0|^6.0|^7.0",
    "symfony/twig-bridge": "^4.0|^5.0|^6.0|^7.0"
  },
  "require-dev": {
    "symfony/phpunit-bridge": "^4.0|^5.0|^6.0|^7.0",
    "symfony/process": "^4.0|^5.0|^6.0|^7.0",
    "symfony/yaml": "^4.0|^5.0|^6.0|^7.0"
  },
  "config": {
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "Imigio\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Imigio\\Tests\\": "tests/"
    }
  }
}
